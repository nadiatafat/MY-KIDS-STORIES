// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: userId (Firebase Auth UID)
// Fields:
//   - uid: string (required)
//   - email: string (required, email format)
//   - displayName: string (optional)
//   - createdAt: string (required, date-time)
//
// Collection: stories
// Document ID: storyId (auto-generated)
// Fields:
//   - userId: string (required) - Owner of the story
//   - title: string (required)
//   - content: string (required) - Markdown content
//   - emotion: string (required) - Primary emotion detected
//   - situation: string (required) - Brief summary of the situation
//   - createdAt: string (required, date-time)
//   - imageUrl: string (optional)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // Default admin check
    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "akram.edn@gmail.com" && request.auth.token.email_verified == true));
    }

    // Domain Validators
    function isValidUser(data) {
      return data.keys().hasOnly(['uid', 'email', 'createdAt', 'role', 'displayName']) &&
             data.uid is string &&
             data.email is string &&
             (data.createdAt is string || data.createdAt is timestamp);
    }

    function isValidStory(data) {
      return data.keys().hasOnly(['userId', 'title', 'content', 'emotion', 'situation', 'createdAt', 'imageUrl']) &&
             data.keys().hasAll(['userId', 'title', 'content', 'emotion', 'situation', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() < 200 &&
             data.content is string && data.content.size() < 10000 &&
             data.emotion is string && data.emotion.size() < 50 &&
             data.situation is string && data.situation.size() < 1000 &&
             (data.createdAt is string || data.createdAt is timestamp) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 2000));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.uid == resource.data.uid;
    }

    match /stories/{storyId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidStory(request.resource.data);
      allow update: if isDocOwner() && isValidStory(request.resource.data) && request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
